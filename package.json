{
  "name": "icloud-mail",
  "description": "View your iCloud mail in a native Windows application.",
  "author": {
    "name": "Taylor Ivanoff"
  },
  "version": "1.0.17",
  "repository": "https://github.com/taylorivanoff/icloud-mail-windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "release": "electron-builder --win --x64 --publish=never"
  },
  "build": {
    "appId": "io.github.taylorivanoff.icloud-mail",
    "productName": "iCloud Mail",
    "win": {
      "icon": "icon.png",
      "target": "nsis",
      "artifactName": "${name}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh",
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "generic",
      "url": "https://github.com/taylorivanoff/icloud-mail-windows/releases/latest/download"
    },
    "protocols": {
      "name": "iCloud Mail",
      "schemes": [
        "icloud-mail"
      ]
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.8",
    "icloud-windows-base": "github:taylorivanoff/icloud-windows-base#v1.0.16"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3"
  }
}
