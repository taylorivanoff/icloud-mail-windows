{
  "name": "icloud-mail",
  "description": "View your iCloud mail in a native Windows application.",
  "author": {
    "name": "Taylor Ivanoff"
  },
  "version": "1.0.7",
  "repository": "https://github.com/taylorivanoff/icloud-mail-windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "release": "electron-builder --win --x64 --publish=never"
  },
  "build": {
    "appId": "io.github.taylorivanoff.icloud-mail",
    "productName": "iCloud Mail",
    "win": {
      "icon": "icon.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh",
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "github",
      "owner": "taylorivanoff",
      "repo": "icloud-mail-windows"
    },
    "protocols": {
      "name": "iCloud Mail",
      "schemes": [
        "icloud-mail"
      ]
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "^30.0.3",
    "electron-builder": "^24.13.3"
  }
}